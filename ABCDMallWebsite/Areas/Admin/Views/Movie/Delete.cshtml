@model Movie

@{
    ViewData["Title"] = "Delete Movie";
}

<h3>Delete Movie</h3>
<p class="text-danger">Do you really want to delete this movie?</p>

<div class="card" style="width: 350px;">
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.ImagePath))
        {
            <img src="@Model.ImagePath" width="100" height="80" class="mb-3" />
        }
        <p><b>Title:</b> @Model.Title</p>
        <p><b>Genre:</b> @Model.Genre</p>
        <p><b>Show Time:</b> @Model.ShowTime.ToString("g")</p>
        <p><b>Total Seats:</b> @Model.TotalSeats</p>
    </div>
</div>

<br />

<!-- Delete confirmation form -->
<form asp-action="Delete" method="post">
    <input asp-for="Id" type="hidden" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
