@model FoodCourt

@{
    ViewData["Title"] = "Add Food Court";
}

<h3>Add Food Court</h3>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="mb-3">
        <label asp-for="CounterName" class="form-label">Counter Name</label>
        <input asp-for="CounterName" class="form-control" />
        <span asp-validation-for="CounterName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="MenuItems" class="form-label">Menu Items</label>
        <textarea asp-for="MenuItems" class="form-control"></textarea>
        <span asp-validation-for="MenuItems" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Upload Image (optional)</label>
        <input type="file" name="imageFile" class="form-control" accept=".png,.jpg,.jpeg" />
    </div>
    <button type="submit" class="btn btn-success">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
