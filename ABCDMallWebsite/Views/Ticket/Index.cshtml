@model List<Movie>

@{
    ViewData["Title"] = "Book Ticket";
}

<div class="container-fluid bg-light py-5 mb-5">
    <div class="container text-center">
        <h1 class="display-4">
            BOOK<span class="text-uppercase text-primary bg-light px-2">TICKET</span>
        </h1>
        <p>"Book your ticket."</p>
    </div>
</div>

<div class="container py-5">
    <h3 class="mb-4 text-center">Select a Movie</h3>
    <div class="row g-4 justify-content-center">
        @foreach (var movie in Model)
        {
            <div class="col-lg-4 col-md-6">
                <div class="card shadow p-3 h-100">
                    <div class="card-body text-center">
                        <h5>@movie.Title</h5>
                        <p class="text-muted">@movie.Genre</p>
                        <p><small>@movie.ShowTime.ToString("dd MMM yyyy hh:mm tt")</small></p>
                        <p>Available Seats: <strong>@(movie.TotalSeats - movie.BookedSeats)</strong></p>
                        <a asp-controller="Ticket" asp-action="Book" asp-route-id="@movie.Id" class="btn btn-primary px-4">Book Now</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>