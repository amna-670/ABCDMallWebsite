@{
    ViewData["Title"] = "Contact Us";
}

<div class="container-fluid bg-light py-5 mb-5">
    <div class="container text-center">
        <h1 class="display-4">
            CONTACT<span class="text-uppercase text-primary bg-light px-2">US</span>
        </h1>
        <p>"We're here to help – get in touch with us today."</p>
    </div>
</div>

<div class="container py-5">
    <div class="row g-4 justify-content-center">

        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4 h-100">
                <i class="fa fa-map-marker-alt fa-3x text-primary mb-3"></i>
                <h5 class="fw-bold">Address</h5>
                <p class="text-muted">ABCD Mall, Sub-Urban Mumbai.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4 h-100">
                <i class="fa fa-phone-alt fa-3x text-primary mb-3"></i>
                <h5 class="fw-bold">Phone</h5>
                <p class="text-muted">+012 345 67890</p>
                <p class="text-muted">+012 345 67891</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4 h-100">
                <i class="fa fa-envelope fa-3x text-primary mb-3"></i>
                <h5 class="fw-bold">Email</h5>
                <p class="text-muted">info@abcdmall.com</p>
                <p class="text-muted">support@abcdmall.com</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4 h-100">
                <i class="fa fa-clock fa-3x text-primary mb-3"></i>
                <h5 class="fw-bold">Opening Hours</h5>
                <p class="text-muted">Monday - Sunday</p>
                <p class="text-muted">10:00 AM - 10:00 PM</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4 h-100">
                <i class="fa fa-car fa-3x text-primary mb-3"></i>
                <h5 class="fw-bold">Parking</h5>
                <p class="text-muted">7 Level Parking Facility</p>
                <p class="text-muted">Available 24/7</p>
            </div>
        </div>

    </div>

    <div class="text-center mt-5">
        <p class="text-muted">Have a query? </p>
        <a asp-controller="Feedback" asp-action="Index" class="btn btn-primary px-4">
            <i class="fa fa-comments me-2"></i>Send us Feedback
        </a>
    </div>

</div>