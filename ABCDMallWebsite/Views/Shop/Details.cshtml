@model Shop

@{
    ViewData["Title"] = Model.Name;
}

<div class="container-fluid bg-light py-5 mb-5">
    <div class="container text-center">
        <h1 class="display-4">@Model.Name</h1>
        <p>@Model.Description</p>
    </div>
</div>

<div class="container mb-5">
    <div class="row">
        <div class="col-md-6 mb-4">
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <img src="@Model.ImagePath" class="img-fluid rounded shadow mb-3 w-75" alt="@Model.Name" />
            }
            else
            {
                <div style="background: linear-gradient(135deg, #3B2A18, #2E2015);
                                padding:60px; text-align:center; border-radius:12px;">
                    <i class="fa fa-store fa-5x" style="color:#F0A202;"></i>
                </div>
            }
        </div>

        <div class="col-md-6">
            <h3>Shop Details</h3>
            <table class="table table-bordered mt-3">
                <tr>
                    <th>Shop Name</th>
                    <td>@Model.Name</td>
                </tr>
                <tr>
                    <th>Description</th>
                    <td>@Model.Description</td>
                </tr>
                <tr>
                    <th>Floor</th>
                    <td>@Model.Floor</td>
                </tr>
            </table>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-secondary px-4">Back to Shops</a>
        </div>

    </div>
</div>
