@model List<Movie>

@{
    ViewData["Title"] = "Movies";
}

<div class="container-fluid bg-light py-5 mb-5">
    <div class="container text-center">
        <h1 class="display-4">
            MO<span class="text-primary">VIES</span>
        </h1>
        <p>Catch the latest blockbusters in our cinema</p>
    </div>
</div>

<div class="container mb-5">
    <h2 class="mb-4">Now Showing</h2>
    <div class="row g-4">
        @foreach (var movie in Model)
        {
            <div class="col-lg-3 col-md-6">
                <div class="card shadow h-100" style="border-radius:12px; overflow:hidden;">
                    @if (movie.ImagePath != null)
                    {
                        <img src="@movie.ImagePath" class="card-img-top" style="height:200px; object-fit:cover;" />
                    }
                    else
                    {
                        <div style="background: linear-gradient(135deg, #3B2A18, #2E2015); padding:30px; text-align:center;">
                            <i class="fa fa-film fa-3x" style="color:#F0A202;"></i>
                        </div>
                    }

                    <div class="card-body text-center d-flex flex-column">
                        <h5 class="fw-bold mb-1">
                            <a asp-controller="Movie" asp-action="Details" asp-route-id="@movie.Id" class="text-dark text-decoration-none">
                                @movie.Title
                            </a>
                        </h5>

                        <span class="badge bg-primary mb-2">@movie.Genre</span>

                        <p class="text-muted small mb-1">
                            <i class="fa fa-clock me-1"></i>
                            @movie.ShowTime.ToString("dd MMM yyyy hh:mm tt")
                        </p>
                        <p class="mb-3">
                            <span class="badge @(movie.TotalSeats - movie.BookedSeats > 0 ? "bg-success" : "bg-danger")">
                                @if (movie.TotalSeats - movie.BookedSeats > 0)
                                {
                                    <span><i class="fa fa-chair me-1"></i>@(movie.TotalSeats - movie.BookedSeats) Seats Available</span>
                                }
                                else
                                {
                                    <span>Housefull!</span>
                                }
                            </span>
                        </p>

                        <div class="mt-auto">
                            @if (movie.TotalSeats - movie.BookedSeats > 0)
                            {
                                <a asp-controller="Ticket" asp-action="Book" asp-route-id="@movie.Id" class="btn btn-primary w-100">
                                    <i class="fa fa-ticket-alt me-2"></i>Book Seat
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-danger w-100" disabled>Housefull!</button>
                            }
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>
</div>
