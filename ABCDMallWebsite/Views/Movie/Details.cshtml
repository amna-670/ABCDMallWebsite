@model Movie

@{
    ViewData["Title"] = Model.Title;
}

<div class="container-fluid bg-light py-5 mb-5">
    <div class="container text-center">
        <h1 class="display-4">@Model.Title</h1>
        <p>@Model.Genre</p>
    </div>
</div>

<div class="container mb-5">
    <div class="row">
        <div class="col-md-4 mb-4">
            @if (Model.ImagePath != null)
            {
                <img src="@Model.ImagePath" class="img-fluid rounded shadow" alt="@Model.Title" />
            }
            else
            {
                <div style="background: linear-gradient(135deg, #3B2A18, #2E2015); padding:60px; text-align:center; border-radius:12px;">
                    <i class="fa fa-film fa-5x" style="color:#F0A202;"></i>
                </div>
            }
        </div>

        <div class="col-md-8">
            <h3>Movie Details</h3>
            <table class="table table-bordered mt-3">
                <tr>
                    <th>Title</th>
                    <td>@Model.Title</td>
                </tr>
                <tr>
                    <th>Genre</th>
                    <td>@Model.Genre</td>
                </tr>
                <tr>
                    <th>Description</th>
                    <td>@Model.Description</td>
                </tr>
                <tr>
                    <th>Show Time</th>
                    <td>@Model.ShowTime.ToString("dd MMM yyyy hh:mm tt")</td>
                </tr>
                <tr>
                    <th>Total Seats</th>
                    <td>@Model.TotalSeats</td>
                </tr>
                <tr>
                    <th>Available Seats</th>
                    <td>@(Model.TotalSeats - Model.BookedSeats)</td>
                </tr>
            </table>

            @if (Model.TotalSeats - Model.BookedSeats > 0)
            {
                <a asp-controller="Ticket" asp-action="Book" asp-route-id="@Model.Id" class="btn btn-primary px-4">
                    <i class="fa fa-ticket-alt me-2"></i>Book Ticket
                </a>
            }
            else
            {
                <button class="btn btn-danger px-4" disabled>Housefull!</button>
            }

            <a asp-controller="Movie" asp-action="Index" class="btn btn-secondary px-4 ms-2">Back to Movies</a>
        </div>

    </div>
</div>
