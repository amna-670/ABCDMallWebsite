<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ABCD Mall Admin</title>

    <link rel="stylesheet" href="~/css/admin.css" />

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome Icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
</head>
<body>

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-brand">
             <span>ABCD</span> Mall
        </div>

        <nav class="nav flex-column mt-2">
            <a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <i class="fas fa-tachometer-alt"></i> Dashboard
            </a>
            <a class="nav-link" asp-area="Admin" asp-controller="Shop" asp-action="Index">
                <i class="fas fa-store"></i> Shops
            </a>
            <a class="nav-link" asp-area="Admin" asp-controller="FoodCourt" asp-action="Index">
                <i class="fas fa-utensils"></i> Food Courts
            </a>
            <a class="nav-link" asp-area="Admin" asp-controller="Movie" asp-action="Index">
                <i class="fas fa-film"></i> Movies
            </a>
            <a class="nav-link" asp-area="Admin" asp-controller="Gallery" asp-action="Index">
                <i class="fas fa-images"></i> Gallery
            </a>
            <a class="nav-link" asp-area="Admin" asp-controller="Feedback" asp-action="Index">
                <i class="fas fa-comments"></i> Feedbacks
            </a>
            <a class="nav-link" asp-area="Admin" asp-controller="Ticket" asp-action="Index">
                <i class="fas fa-ticket-alt"></i> Tickets
            </a>

            <hr style="border-color: rgba(255,255,255,0.1);" />

            <a class="nav-link text-danger" asp-area="Admin" asp-controller="Account" asp-action="Logout">
                <i class="fas fa-sign-out-alt"></i> Logout
            </a>
        </nav>
    </div>

    <!-- Top Navbar -->
    <div class="top-navbar">
        <span class="fw-semibold text-muted">Admin Panel</span>
        <span class="admin-name">
            <i class="fas fa-user-circle me-1"></i>
            @Context.Session.GetString("AdminName")
        </span>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        @RenderBody()
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>