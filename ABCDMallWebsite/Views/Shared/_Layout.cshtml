<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>ABCD-MALL</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <!-- Favicon -->
    <link href="@Url.Content("~/img/favicon.ico")" rel="icon">

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700;9..144,800&family=Nunito+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">

    <!-- Icon Fonts -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Libraries -->
    <link href="@Url.Content("~/lib/animate/animate.min.css")" rel="stylesheet">
    <link href="@Url.Content("~/lib/owlcarousel/assets/owl.carousel.min.css")" rel="stylesheet">

    <!-- Bootstrap -->
    <!-- Bootstrap CDN - file ki zarurat nahi -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Main CSS -->
    <link href="@Url.Content("~/css/style.css")" rel="stylesheet">
</head>

<body>
    <!-- Spinner Start -->
    <div id="spinner"
         class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-grow text-primary" style="width: 3rem; height: 3rem;" role="status">
            <span class="sr-only">Loading...</span>
        </div>
    </div>
    <!-- Spinner End -->

    <div class="container-fluid sticky-top">
        <div class="container">
            @{
                var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
                var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
            }

            <nav class="navbar navbar-expand-lg navbar-light">

                <a asp-controller="Home" asp-action="Index" class="navbar-brand">
                    <h1><span class="brand-mark"><i class="fa fa-store"></i></span>ABCD <span class="text-primary">Mall</span></h1>
                </a>

                <button type="button" class="navbar-toggler ms-auto me-0"
                        data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarCollapse">
                    <div class="navbar-nav ms-auto">

                        <a asp-controller="Home" asp-action="Index"
                           class="nav-item nav-link @(currentController == "Home" && currentAction == "Index" ? "active" : "")">
                            Home
                        </a>

                        <a asp-controller="Shop" asp-action="Index"
                           class="nav-item nav-link @(currentController == "Shop" ? "active" : "")">
                            Shops
                        </a>

                        <a asp-controller="FoodCourt" asp-action="Index"
                           class="nav-item nav-link @(currentController == "FoodCourt" ? "active" : "")">
                            Food Court
                        </a>

                        <a asp-controller="Movie" asp-action="Index"
                           class="nav-item nav-link @(currentController == "Movie" ? "active" : "")">
                            Movies
                        </a>

                        <a asp-controller="Gallery" asp-action="Index"
                           class="nav-item nav-link @(currentController == "Gallery" ? "active" : "")">
                            Gallery
                        </a>

                        <a asp-controller="Home" asp-action="Contact"
                           class="nav-item nav-link @(currentController == "Home" && currentAction == "Contact" ? "active" : "")">
                            Contact
                        </a>

                        <a asp-controller="Feedback" asp-action="Index"
                           class="nav-item nav-link @(currentController == "Feedback" ? "active" : "")">
                            Feedback
                        </a>

                    </div>
                </div>
            </nav>
        </div>
    </div>

    <main>
        @RenderBody()
    </main>

    <!-- Footer Start -->
    <div class="container-fluid bg-mall-ink text-white-50 footer pt-5">
        <div class="container py-5">
            <div class="row g-5">
                <div class="col-md-6 col-lg-3 wow fadeIn" data-wow-delay="0.1s">
                    <a asp-controller="Home" asp-action="Index" class="d-inline-block mb-3">
                        <h1 class="text-white">ABCD <span class="text-primary">Mall</span></h1>
                    </a>
                    <p class="mb-0">
                        ABCD Mall is a modern shopping destination offering top brands,
                        food court, multiplex cinema and entertainment for families.
                    </p>
                </div>
                <div class="col-md-6 col-lg-3 wow fadeIn" data-wow-delay="0.3s">
                    <h5 class="text-white mb-4">Get In Touch</h5>
                    <p><i class="fa fa-map-marker-alt me-3"></i>123 Street, Mumbai, India</p>
                    <p><i class="fa fa-phone-alt me-3"></i>+012 345 67890</p>
                    <p><i class="fa fa-envelope me-3"></i>info@abcdmall.com</p>
                    <div class="d-flex pt-2">
                        <a class="btn btn-outline-primary btn-square border-2 me-2" href="https://x.com/">
                            <i class="fab fa-twitter"></i>
                        </a>
                        <a class="btn btn-outline-primary btn-square border-2 me-2" href="https://www.facebook.com/">
                            <i class="fab fa-facebook-f"></i>
                        </a>
                        <a class="btn btn-outline-primary btn-square border-2 me-2" href="https://www.youtube.com/">
                            <i class="fab fa-youtube"></i>
                        </a>
                        <a class="btn btn-outline-primary btn-square border-2 me-2" href="https://www.instagram.com/?hl=en">
                            <i class="fab fa-instagram"></i>
                        </a>
                        <a class="btn btn-outline-primary btn-square border-2 me-2" href="https://www.linkedin.com/home">
                            <i class="fab fa-linkedin-in"></i>
                        </a>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3 wow fadeIn" data-wow-delay="0.5s">
                    <h5 class="text-white mb-4">Quick Links</h5>
                    <a class="btn btn-link" asp-controller="Home" asp-action="Index">Home</a>
                    <a class="btn btn-link" asp-controller="Shop" asp-action="Index">Shops</a>
                    <a class="btn btn-link" asp-controller="FoodCourt" asp-action="Index">Food Court</a>
                    <a class="btn btn-link" asp-controller="Movie" asp-action="Index">Movies</a>
                    <a class="btn btn-link" asp-controller="Home" asp-action="Contact">Contact</a>
                </div>
                <div class="col-md-6 col-lg-3 wow fadeIn" data-wow-delay="0.7s">
                    <h5 class="text-white mb-4">Our Services</h5>
                    <a class="btn btn-link" asp-controller="Shop" asp-action="Index">Shopping</a>
                    <a class="btn btn-link" asp-controller="FoodCourt" asp-action="Index">Food Court</a>
                    <a class="btn btn-link" asp-controller="Movie" asp-action="Index">Cinema</a>
                    <a class="btn btn-link" asp-controller="Gallery" asp-action="Index">Gallery</a>
                    <a class="btn btn-link" asp-controller="Feedback" asp-action="Index">Feedback</a>
                    <a class="btn btn-link" asp-area="Admin" asp-controller="Account" asp-action="Login">Admin Dashboard</a>
                </div>
            </div>
        </div>
        <div class="container wow fadeIn" data-wow-delay="0.1s">
            <div class="copyright">
                <div class="row">
                    <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                        &copy; ABCD Mall, All Right Reserved.
                    </div>
                    <div class="col-md-6 text-center text-md-end">
                        <div class="footer-menu">
                            <a asp-controller="Home" asp-action="Index">Home</a>
                            <a asp-controller="Home" asp-action="Contact">Contact</a>
                            <a asp-controller="Feedback" asp-action="Index">Feedback</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Footer End -->
    <!-- Back to Top -->
    <a href="#!" class="btn btn-lg btn-primary btn-lg-square back-to-top">
        <i class="bi bi-arrow-up"></i>
    </a>

    <!-- JavaScript Libraries -->
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/lib/easing/easing.min.js"></script>
    <script src="/lib/waypoints/waypoints.min.js"></script>
    <script src="/lib/owlcarousel/owl.carousel.min.js"></script>
    <script src="/lib/wow/wow.min.js"></script>
    <!-- Template Javascript -->
    <script src="/js/main.js"></script>
</body>
</html>