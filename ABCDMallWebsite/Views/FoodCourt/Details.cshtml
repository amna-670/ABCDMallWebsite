@model FoodCourt

@{
    ViewData["Title"] = @Model.CounterName;
}

<div class="container-fluid bg-light py-5 mb-5">
    <div class="container text-center">
        <h1 class="display-4">@Model.CounterName</h1>
        <p>@Model.MenuItems</p>
    </div>
</div>

<div class="container mb-5">
    <div class="row">
        <div class="col-md-6">
            @if (Model.ImagePath != null)
            {
                <img src="@Model.ImagePath" class="img-fluid rounded mb-3" alt="@Model.CounterName" />
            }
        </div>

        <div class="col-md-6">
            <table class="table table-bordered">
                <tr>
                    <th>Counter Name</th>
                    <td>@Model.CounterName</td>
                </tr>
                <tr>
                    <th>Menu Items</th>
                    <td>@Model.MenuItems</td>
                </tr>
            </table>
            <a asp-controller="FoodCourt" asp-action="Index" class="btn btn-secondary px-4">Back to Food Courts</a>
        </div>
    </div>
</div>
